# ─── UTOE Environment Configuration ──────────────────────────────────────────
# Copy this to .env.utoe and fill in your API keys.
# Only set keys for providers you want to use.
# UTOE will automatically prefer Ollama (free, local) → Groq → Anthropic → OpenAI.

# ── Provider API Keys ─────────────────────────────────────────────────────────
# Get from: platform.openai.com
OPENAI_API_KEY=

# Get from: console.anthropic.com
ANTHROPIC_API_KEY=

# Get from: console.groq.com (free tier available — very fast!)
GROQ_API_KEY=

# Get from: aistudio.google.com
GEMINI_API_KEY=

# Get from: console.mistral.ai
MISTRAL_API_KEY=

# Get from: dashboard.cohere.com
COHERE_API_KEY=

# Get from: api.together.ai
TOGETHER_API_KEY=

# ── Ollama (local, free) ───────────────────────────────────────────────────────
# Install: https://ollama.ai
# Then run: ollama pull llama3.1
OLLAMA_URL=http://localhost:11434

# ── UTOE Settings ─────────────────────────────────────────────────────────────
# Port for the proxy server (set OPENAI_BASE_URL=http://localhost:8787/v1)
UTOE_PORT=8787

# Max input tokens (hard limit — prevents huge context window bills)
UTOE_MAX_TOKENS=16000

# How many history turns to keep per session
UTOE_HISTORY_WINDOW=6

# Max output tokens per response
UTOE_OUTPUT_LIMIT=1024

# Execution mode:
#   bridge = optimizes prompts only, passes them to original AI tool (default)
#   proxy  = UTOE calls the LLM directly using your API keys
UTOE_MODE=bridge

# GPU detection (optional — improves Ollama model selection)
# UTOE_GPU=true

# Custom telemetry output file (default: .utoe_telemetry.jsonl in cwd)
# UTOE_TELEMETRY_FILE=.utoe_telemetry.jsonl
